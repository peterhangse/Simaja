rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Worlds - require name and createdAt on create
    match /worlds/{worldId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name', 'createdAt'])
                    && request.resource.data.name is string;
      allow update: if request.auth != null && request.resource.data.name is string;
      allow delete: if request.auth != null;
    }
    
    // Houses - require name and worldId
    match /houses/{houseId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name', 'worldId', 'createdAt'])
                    && request.resource.data.name is string;
      allow update: if request.auth != null && request.resource.data.name is string;
      allow delete: if request.auth != null;
    }
    
    // Sims - require name
    match /sims/{simId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name', 'createdAt'])
                    && request.resource.data.name is string;
      allow update, delete: if request.auth != null;
    }
    
    // Relationships - require both sim IDs and type
    match /relationships/{relId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['sim1Id', 'sim2Id', 'type'])
                    && request.resource.data.type is string;
      allow update, delete: if request.auth != null;
    }
    
    // Diary entries - require simId, text, and date
    match /diary/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['simId', 'text', 'date'])
                    && request.resource.data.text is string;
      allow update, delete: if request.auth != null;
    }

    // Profiles - require name on create
    match /profiles/{profileId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name', 'createdAt'])
                    && request.resource.data.name is string;
      allow update, delete: if request.auth != null;
    }
  }
}
